# Porta do servidor Express
PORT=3333

# Supabase — pegue em: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role
SUPABASE_ANON_KEY=sua_chave_anon

# Origens permitidas no CORS (separadas por vírgula). Em produção, a URL do frontend.
CORS_ORIGIN=http://localhost:5173

# Pexels — usado só pelo script de seed (seed-loja.ts). Gratuito em https://www.pexels.com/api/
PEXELS_API_KEY=sua_chave_pexels
